// Test: Postfix-Fakultät n!
fn main() {
    print("--- Dedekind: Fakultät mit n! Syntax ---")
    
    // Einfache Fakultäten
    beispiel = 5
    faculty = beispiel!
    print("5! =")
    print(faculty)
    
    // Weitere Beispiele
    print("3! =")
    print(3!)
    
    print("0! =")
    print(0!)
    
    print("1! =")
    print(1!)
    
    // Fakultät in Ausdrücken
    result = 2 * 3!
    print("2 * 3! =")
    print(result)
    
    // Fakultät mit Variable
    n = 4
    fact_n = n!
    print("4! =")
    print(fact_n)
    
    print("Fakultät-Test erfolgreich!")
}
main()
