fn check_value(x) {
    if x > 50 {
        print("Value is large")
    } else {
        if x == 0 {
            print("Value is zero")
        } else {
            print("Value is small")
        }
    }
}

fn main() {
    values = [0, 10, 100]

    for v in values {
        print("Testing:")
        print(v)
        check_value(v)
    }
}
main()
