//Test: postfix factorial n!
fn main() {
    print("--- Dedekind: factorial with n! syntax ---")

    // Simple factorials
    beispiel = 5
    faculty = beispiel!
    print("5! =")
    print(faculty)

    // More examples
    print("3! =")
    print(3!)

    print("0! =")
    print(0!)

    print("1! =")
    print(1!)

    // Factorial in expressions
    result = 2 * 3!
    print("2 * 3! =")
    print(result)

    // Factorial with variable
    n = 4
    fact_n = n!
    print("4! =")
    print(fact_n)

    print("Factorial test successful!")
}
main()
