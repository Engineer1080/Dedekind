fn main() {
    // Mathematical vectors
    v1 = [10.5, 20.0, 30.2]
    v2 = [1.0, 2.0, 3.0]

    print("Vector 1:")
    print(v1)

    print("Vector 2:")
    print(v2)

    // Simple addition (automatically treated as a tensor)
    total = v1 + v2
    print("Sum:")
    print(total)

    // Scalar product-like operation
    print("Vector 1 scaled:")
    print(v1 * 5)
}
main()
