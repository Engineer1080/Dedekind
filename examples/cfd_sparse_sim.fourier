    // 1. Initial Temperature Field (Delta distribution in the middle)
    T = random_matrix(N, N) * 0.0
    T[50][50] = 100.0 // Heat source in the center
    
    // In a real CFD/FEM code, we'd build a sparse Laplacian L.
