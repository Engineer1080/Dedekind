// Tests for the differentiable ellipse mask + shape optimization.

use fluid_dynamics

fn test_ellipse_mask_shape() {
    print("Testing soft_ellipse_mask shape...")
    M = soft_ellipse_mask(40, 30, 20.0, 15.0, 5.0, 3.0, 0.3)
    assert(M.shape[0] == 40)
    assert(M.shape[1] == 30)

    // Center must be ~ 1
    center = M[20][15]
    print("  Mask at center:", center)
    assert(center > 0.95)

    // Far away must be ~ 0
    far = M[0][0]
    print("  Mask at corner:", far)
    assert(far < 0.05)
    print("[OK] Ellipse mask shape")
}

fn drag_of_ellipse(x_arr) {
    aspect_log = x_arr[0]
    aspect     = exp(aspect_log)
    V = 6.0
    a = sqrt(V * aspect)
    b = V / a
    M = soft_ellipse_mask(40, 24, 12.0, 12.0, a, b, 0.3)
    sim = lbm_simulation_full(40, 24, 0.7, M, 0.05)
    simulation_run(sim, 50, 0.05)
    F = simulation_get_drag_lift(sim)
    return [F[0]]
}

fn test_ellipse_drag_gradient() {
    print("Testing gradient of drag w.r.t. ellipse aspect (autograd vs FD)...")
    // Autograd
    j = jacobian(drag_of_ellipse, [0.0])
    grad_ag = j[0][0]

    // Finite differences
    h = 0.01
    fp = drag_of_ellipse([h])[0]
    fm = drag_of_ellipse([-h])[0]
    grad_fd = (fp - fm) / (2.0 * h)

    rel_err = abs(grad_ag - grad_fd) / abs(grad_fd)
    print("  Autograd gradient:", grad_ag)
    print("  FD gradient:      ", grad_fd)
    print("  Rel. error:       ", rel_err)
    assert(rel_err < 1e-3)
    print("[OK] Ellipse drag is end-to-end differentiable")
}

fn test_shape_optimization_reduces_drag() {
    print("Testing that Adam reduces drag via shape optimization...")
    x0 = [0.0]                        // circle (a/b = 1)
    d_circle = drag_of_ellipse(x0)[0]

    // Short Adam run (few steps, low resolution)
    result = minimize(drag_of_ellipse, x0, "adam", 0.2, 6)
    x_opt  = result[0]
    d_opt  = drag_of_ellipse([x_opt[0]])[0]
    aspect = exp(x_opt[0])

    print("  Drag (circle):    ", d_circle)
    print("  Drag (optimized): ", d_opt)
    print("  a/b after opt:    ", aspect)

    assert(d_opt < d_circle)          // Adam finds a better shape
    assert(aspect > 1.1)              // optimum is slimmer than the circle
    print("[OK] Shape optimization reduces drag")
}

fn main() {
    test_ellipse_mask_shape()
    test_ellipse_drag_gradient()
    test_shape_optimization_reduces_drag()
}
main()
