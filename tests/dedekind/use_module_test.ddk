// Modul-System: `use mathlib` lädt modules/mathlib.ddk und stellt square/cube/PHI bereit.
use mathlib

fn main() {
    assert(square(4) == 16, "square(4) == 16")
    assert(cube(3) == 27, "cube(3) == 27")
    assert(PHI > 1.6 and PHI < 1.7, "PHI ungefähr 1.618")
    print("use_module_test OK")
}
main()
