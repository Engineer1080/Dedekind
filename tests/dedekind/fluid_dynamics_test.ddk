use fluid_dynamics

fn test_lbm_init() {
    print("Testing LBM Initialization...")
    sim = lbm_simulation(30, 20, 0.8)
    
    rho = simulation_get_density(sim)
    vel = simulation_get_velocity(sim)
    
    print("Density shape:", rho.shape)
    print("Velocity shape:", vel.shape)
    
    assert(rho.shape[0] == 30)
    assert(rho.shape[1] == 20)
    assert(vel.shape[0] == 2)
    assert(vel.shape[1] == 30)
    assert(vel.shape[2] == 20)
    
    print("[OK] LBM Initialization")
}

fn test_lbm_step() {
    print("Testing LBM Step & Run...")
    sim = lbm_simulation(30, 20, 0.8)
    
    simulation_step(sim, 0.05)
    simulation_run(sim, 5, 0.05)
    
    rho = simulation_get_density(sim)
    print("Mean density after 6 steps:", mean(rho))
    assert(mean(rho) > 0.0)
    
    print("[OK] LBM Step & Run")
}

fn test_lbm_autograd() {
    print("Testing LBM Autograd (Gradient flow from Drag to Radius)...")
    
    nx = 20
    ny = 10
    
    fn get_drag_from_radius(r_arr) {
        r = r_arr[0]
        
        // Erzeuge Zylindermaske mit Radius r
        mask = soft_cylinder_mask(nx, ny, 8.0, 5.0, r, 0.5)
        
        // Initialisiere Simulation mit Maske
        sim = lbm_simulation_with_mask(nx, ny, 0.8, mask)
        
        // Lasse Simulation für 4 Schritte laufen
        simulation_run(sim, 4, 0.05)
        
        // Berechne Widerstandskraft
        forces = simulation_get_drag_lift(sim)
        drag = forces[0]
        return [drag]
    }
    
    // Initialer Radius als 1-elementiger Vektor für jacobian
    r_init = [1.5]
    
    // Berechne Ableitung der Drag-Kraft nach dem Radius r
    deriv = jacobian(get_drag_from_radius, r_init)
    print("Derivative of drag w.r.t radius r:", deriv)
    
    // Die Ableitung muss ungleich Null sein, da größerer Radius mehr Widerstand erzeugt
    // d(drag)/d(r) sollte positiv sein!
    assert(deriv[0][0] > 0.0)
    
    print("[OK] LBM Autograd")
}

fn test_lbm_reynolds() {
    print("Testing Reynolds helpers...")
    // Re = u*L/nu, nu = (tau-0.5)/3 → bei tau=0.8, u=0.05, L=10: Re=5
    re = lbm_reynolds(0.05, 10.0, 0.8)
    print("Re(u=0.05, L=10, tau=0.8) =", re)
    assert(abs(re - 5.0) < 1e-9)

    // Umkehr: tau aus Re
    tau = lbm_tau_from_reynolds(100.0, 0.05, 20.0)
    print("tau(Re=100, u=0.05, L=20) =", tau)
    // nu = u*L/Re = 0.01, tau = 3*nu + 0.5 = 0.53
    assert(abs(tau - 0.53) < 1e-9)

    print("[OK] Reynolds helpers")
}

fn test_lbm_stability_check() {
    print("Testing tau stability check...")
    caught = false
    try {
        // tau=0.5 muss als instabil abgelehnt werden
        sim = lbm_simulation(10, 10, 0.5)
    } catch e {
        caught = true
        print("Erwarteter Fehler:", e)
    }
    assert(caught)
    print("[OK] tau stability check")
}

fn test_lbm_mem_no_obstacle() {
    print("Testing MEM-Drag returns zero without obstacle...")
    sim = lbm_simulation(20, 12, 0.8)
    simulation_run(sim, 10, 0.05)
    forces = simulation_get_drag_lift(sim)
    print("F_x, F_y (no obstacle):", forces)
    // Ohne Hindernis: M=0 überall, MEM-Force muss exakt 0 sein
    assert(abs(forces[0]) < 1e-12)
    assert(abs(forces[1]) < 1e-12)
    print("[OK] MEM zero-obstacle invariant")
}

fn test_lbm_pressure() {
    print("Testing pressure field...")
    sim = lbm_simulation(15, 10, 0.8)
    simulation_run(sim, 5, 0.05)
    p = simulation_get_pressure(sim)
    rho = simulation_get_density(sim)
    print("p shape:", p.shape, " rho shape:", rho.shape)
    // p = rho/3 in Lattice-Einheiten
    diff = abs(mean(p) * 3.0 - mean(rho))
    print("mean(p)*3 - mean(rho) =", diff)
    assert(diff < 1e-6)
    print("[OK] pressure = rho/3")
}

fn test_karman_quick() {
    print("Testing Karman benchmark (quick: 1500 steps, klein)...")
    // Sehr kurze Variante; misst nur, dass die API durchläuft und plausible
    // Werte liefert (nicht textbook-Konvergenz).
    result = lbm_karman_benchmark(100.0, 120, 40, 1500)
    cd = result["C_D_mean"]
    st = result["strouhal"]
    print("C_D =", cd, "  St =", st)
    // Sehr lockere Schranken; bei dieser Auflösung erwarten wir nur Größenordnung
    assert(cd > 0.5)
    assert(cd < 6.0)
    assert(st >= 0.0)
    print("[OK] Karman benchmark API")
}

fn main() {
    test_lbm_init()
    test_lbm_step()
    test_lbm_autograd()
    test_lbm_reynolds()
    test_lbm_stability_check()
    test_lbm_mem_no_obstacle()
    test_lbm_pressure()
    test_karman_quick()
}
main()
