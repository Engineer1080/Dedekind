// Tests for print_table with several formats and UncertainQuantity.

fn check_contains(haystack, needle, label) {
    // We use str.find() (Python passthrough); -1 means "not found".
    pos = haystack.find(needle)
    assert(pos >= 0, label)
}

fn main() {
    // 1) Simple table
    rows = [[1, 2.5, "x"], [3, 4.5, "y"]]
    headers = ["a", "b", "c"]
    md = print_table(rows, headers=headers, format="markdown")
    check_contains(md, "| a | b   | c |", "markdown header with a/b/c")
    check_contains(md, "1 | 2.5 | x", "first row")

    // 2) CSV format
    csv = print_table(rows, headers=headers, format="csv")
    check_contains(csv, "a,b,c", "CSV header")
    check_contains(csv, "1,2.5,x", "CSV row")

    // 3) LaTeX format
    tex = print_table(rows, headers=headers, format="latex", caption="Demo", label="tab:t")
    check_contains(tex, r"\begin{tabular}", "LaTeX tabular")
    check_contains(tex, r"\toprule", "booktabs toprule")
    check_contains(tex, r"\caption{Demo}", "LaTeX caption")

    // 4) UncertainQuantity: +/- with unit
    rows_u = [["U1", uncertain(2.34, 0.05, unit="V")]]
    md_u = print_table(rows_u, headers=["Measurement", "Voltage"], format="markdown")
    check_contains(md_u, "2.34 ± 0.05 [V]", "markdown +/- with unit")

    tex_u = print_table(rows_u, headers=["Measurement", "Voltage"], format="latex")
    check_contains(tex_u, r"\pm", "LaTeX \pm")
    check_contains(tex_u, r"\mathrm{V}", "LaTeX unit as mathrm")

    // 5) DataFrame with units in the header
    df = DataFrame({"t": [0.0, 1.0], "T": [20.0, 22.5]}, units={"t": "s", "T": "K"})
    md_df = print_table(df, format="markdown")
    check_contains(md_df, "t [s]", "DataFrame header carries unit")
    check_contains(md_df, "T [K]", "DataFrame header carries the second unit")

    print("paper_table_test OK")
}
main()
