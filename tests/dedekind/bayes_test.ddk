fn approx(a, b, tol) {
    d = a - b
    if d < 0 { d = -d }
    return d < tol
}

fn main() {
    print("--- Dedekind: NUTS & VI Tests ---")

    data = [2.9, 3.1, 3.0, 3.2, 2.8] // mean is 3.0
    prior = Normal(0.0, 10.0)
    
    fn log_prior(theta) {
        return log_prob(prior, theta)
    }
    fn log_likelihood(data, theta) {
        return log_prob(Normal(theta[0], 1.0), data)
    }

    init_theta = [0.0]

    // 1. Test NUTS
    samples = nuts(log_prior, log_likelihood, data, init_theta, 100, 0.2, 5)
    // Average of last 20 samples should be close to 3.0
    sum_val = 0.0
    for i in range(20) {
        idx = 80 + i
        sum_val = sum_val + samples[idx][0]
    }
    avg_val = sum_val / 20.0
    print("NUTS posterior average (last 20):")
    print(avg_val)
    assert(approx(avg_val, 3.0, 0.5), "NUTS should converge near 3.0")

    // 2. Test VI
    vi_res = vi(log_prior, log_likelihood, data, init_theta, 500, 0.1, 10)
    mu = vi_res[0]
    sigma = vi_res[1]
    print("VI mu:")
    print(mu[0])
    print("VI sigma:")
    print(sigma[0])
    assert(approx(mu[0], 3.0, 0.4), "VI mean should be near 3.0")
    assert(approx(sigma[0], 0.45, 0.2), "VI std should be near 0.45")

    // 3. Test fit with method="nuts"
    fn simple_loss(p, d) {
        diff = p[0] - d[0]
        return diff * diff
    }
    fit_samples = fit(simple_loss, [0.0], [5.0], method="nuts", lr=0.1, steps=100)
    sum_fit = 0.0
    for i in range(20) {
        idx = 80 + i
        sum_fit = sum_fit + fit_samples[idx][0]
    }
    avg_fit = sum_fit / 20.0
    print("Fit NUTS average (last 20):")
    print(avg_fit)
    assert(approx(avg_fit, 5.0, 0.5), "fit(method=nuts) should converge near 5.0")

    // 4. Test fit with method="vi"
    fit_vi = fit(simple_loss, [0.0], [5.0], method="vi", lr=0.1, steps=200)
    print("Fit VI result:")
    print(fit_vi[0])
    assert(approx(fit_vi[0], 5.0, 0.4), "fit(method=vi) should be near 5.0")

    print("bayes_test: all assertions passed")
}

main()
