// Tests for Fourier-based shape parameterization + multi-parameter optimization.

use fluid_dynamics

fn test_fourier_mask_circle() {
    print("Testing fourier_shape_mask: zero coefficients -> circle...")
    a = [0.0, 0.0, 0.0]
    b = [0.0, 0.0, 0.0]
    M = fourier_shape_mask(40, 30, 20.0, 15.0, 5.0, a, b, 0.3)

    assert(M.shape[0] == 40)
    assert(M.shape[1] == 30)
    // Center ~ 1
    assert(M[20][15] > 0.95)
    // Point on the circle boundary (distance 5): ~ 0.5
    edge = M[25][15]    // distance 5 in x
    print("  Value at the radius (~0.5):", edge)
    assert(edge > 0.3)
    assert(edge < 0.7)
    print("[OK] Circle special case")
}

fn test_fourier_mask_asymmetric() {
    print("Testing fourier_shape_mask: a_1 > 0 -> tear-drop shape...")
    a = [0.4, 0.0, 0.0]   // first harmonic -> asymmetry in x
    b = [0.0, 0.0, 0.0]
    M = fourier_shape_mask(40, 30, 20.0, 15.0, 5.0, a, b, 0.3)

    // r(theta=0)  = 5 * (1 + 0.4) = 7  -> point (27, 15) is inside
    // r(theta=pi) = 5 * (1 - 0.4) = 3  -> point (16, 15) is outside (distance 4 > 3)
    right_inside = M[26][15]
    left_outside = M[16][15]
    print("  right (theta=0, should be inside):", right_inside)
    print("  left  (theta=pi, should be outside):", left_outside)
    assert(right_inside > 0.7)
    assert(left_outside < 0.3)
    print("[OK] Asymmetric shape (tear-drop)")
}

fn drag_of_fourier(coeffs) {
    a = [coeffs[0], coeffs[1]]
    b = [coeffs[2], coeffs[3]]
    M = fourier_shape_mask(40, 24, 12.0, 12.0, 3.0, a, b, 0.3)
    sim = lbm_simulation_full(40, 24, 0.7, M, 0.05)
    simulation_run(sim, 60, 0.05)
    F = simulation_get_drag_lift(sim)
    return [F[0]]
}

fn test_fourier_drag_gradient() {
    print("Testing autograd gradient w.r.t. all Fourier coefficients...")
    x0 = [0.0, 0.0, 0.0, 0.0]
    j = jacobian(drag_of_fourier, x0)

    // Validation against finite differences for a_1 (first component)
    h = 0.01
    fp = drag_of_fourier([h, 0.0, 0.0, 0.0])[0]
    fm = drag_of_fourier([-h, 0.0, 0.0, 0.0])[0]
    fd_grad_a1 = (fp - fm) / (2.0 * h)
    ag_grad_a1 = j[0][0]

    print("  Autograd d_drag/d_a_1:", ag_grad_a1)
    print("  Finite diff          :", fd_grad_a1)
    rel_err = abs(ag_grad_a1 - fd_grad_a1) / (abs(fd_grad_a1) + 1e-12)
    print("  Rel. error           :", rel_err)
    assert(rel_err < 1e-2)
    print("[OK] Multi-parameter autograd")
}

fn test_fourier_multi_param_optimization() {
    print("Testing that Adam finds a multi-parameter minimum...")
    x0 = [0.0, 0.0, 0.0, 0.0]
    d0 = drag_of_fourier(x0)[0]

    // Short Adam run
    result = minimize(drag_of_fourier, x0, "adam", 0.05, 8)
    x_opt = result[0]
    d_opt = drag_of_fourier([x_opt[0], x_opt[1], x_opt[2], x_opt[3]])[0]

    print("  Drag circle:    ", d0)
    print("  Drag optimized: ", d_opt)
    assert(d_opt < d0)
    print("[OK] 4-parameter optimization reduces drag")
}

fn main() {
    test_fourier_mask_circle()
    test_fourier_mask_asymmetric()
    test_fourier_drag_gradient()
    test_fourier_multi_param_optimization()
}
main()
