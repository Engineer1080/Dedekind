// Tests for partial(u, x, order=n) — autograd derivative of network outputs
// w.r.t. network inputs. No neural net needed: we verify against the
// analytical derivatives of simple functions.

fn approx(a, b, tol) {
    d = a - b
    if d < 0 { d = -d }
    return d < tol
}

fn main() {
    // 1) u(x) = x^2  =>  u'(x) = 2x,  u''(x) = 2
    x = linspace(-1.0, 1.0, 5).with_grad()
    u = x * x
    du = partial(u, x)
    d2u = partial(u, x, order=2)

    assert(approx(du[0].item(), -2.0, 1e-6), "u=x^2: u'(-1) = -2")
    assert(approx(du[2].item(),  0.0, 1e-6), "u=x^2: u'(0) = 0")
    assert(approx(du[4].item(),  2.0, 1e-6), "u=x^2: u'(1) = 2")
    assert(approx(d2u[0].item(), 2.0, 1e-6), "u=x^2: u'' = 2")
    assert(approx(d2u[4].item(), 2.0, 1e-6), "u=x^2: u'' = 2")

    // 2) u(x) = sin(x)  =>  u'(x) = cos(x)
    x2 = linspace(0.0, 3.14159265, 4).with_grad()
    u2 = sin(x2)
    du2 = partial(u2, x2)
    assert(approx(du2[0].item(), 1.0, 1e-4), "sin'(0) = 1")
    assert(approx(du2[3].item(), -1.0, 1e-3), "sin'(pi) = -1")

    // 3) u(x) = x^3 - 4x  =>  u'(x) = 3x^2 - 4
    x3 = linspace(-2.0, 2.0, 5).with_grad()
    u3 = x3 * x3 * x3 - 4.0 * x3
    du3 = partial(u3, x3)
    assert(approx(du3[0].item(), 8.0, 1e-5), "u=x^3-4x: u'(-2) = 8")
    assert(approx(du3[2].item(), -4.0, 1e-5), "u=x^3-4x: u'(0) = -4")
    assert(approx(du3[4].item(), 8.0, 1e-5), "u=x^3-4x: u'(2) = 8")

    // 4) u(x) = x^3 - 4x  =>  u''(x) = 6x
    d2u3 = partial(u3, x3, order=2)
    assert(approx(d2u3[0].item(), -12.0, 1e-5), "u=x^3-4x: u''(-2) = -12")
    assert(approx(d2u3[2].item(),  0.0, 1e-5), "u=x^3-4x: u''(0) = 0")
    assert(approx(d2u3[4].item(), 12.0, 1e-5), "u=x^3-4x: u''(2) = 12")

    // 5) Multidimensional input: f(x, y) = x^2 + y^2  -> gradient w.r.t. (x, y)
    //    .reshape(-1, 2): two input components per row
    xy = linspace(1.0, 4.0, 4).reshape(-1, 2).with_grad()
    // xy = [[1, 2], [3, 4]]
    // f = x^2 + y^2  -> per row: [5, 25]
    // df/dx = 2x -> [2, 6]; df/dy = 2y -> [4, 8]
    f = xy.narrow(1, 0, 1) * xy.narrow(1, 0, 1) + xy.narrow(1, 1, 1) * xy.narrow(1, 1, 1)
    grad_f = partial(f, xy)
    assert(approx(grad_f[0][0].item(), 2.0, 1e-6), "df/dx at (1,2) = 2")
    assert(approx(grad_f[0][1].item(), 4.0, 1e-6), "df/dy at (1,2) = 4")
    assert(approx(grad_f[1][0].item(), 6.0, 1e-6), "df/dx at (3,4) = 6")
    assert(approx(grad_f[1][1].item(), 8.0, 1e-6), "df/dy at (3,4) = 8")

    print("partial_test: 17 asserts passed")
}

main()
