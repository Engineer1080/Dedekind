// Tests for modules/chemistry.ddk
use chemistry

fn approx(a, b, tol) {
    d = a - b
    if d < 0 { d = -d }
    return d < tol
}

fn main() {
    // pH from [H+] = 1e-3 -> pH = 3
    assert(approx(pH_from_concentration(1e-3), 3.0, 1e-6), "pH")

    // Henderson-Hasselbalch: equal concentrations -> pH = pKa
    assert(approx(henderson_hasselbalch(4.76, 0.1, 0.1), 4.76, 1e-6), "HH at [A-]=[HA]")

    // Dilution c1*v1 = c2*v2
    v2 = dilution_volume(1.0, 0.025, 0.1)
    assert(approx(v2, 0.25, 1e-9), "dilution")

    // Molarity
    assert(approx(molarity(0.5, 2.0), 0.25, 1e-9), "molarity")

    // Boyle: p1*v1=p2*v2 -> half pressure = double volume
    v_new = boyle_volume(2.0, 0.5, 1.0)
    assert(approx(v_new, 1.0, 1e-9), "Boyle")

    // Charles: V/T constant
    v_t = charles_volume(1.0, 300.0, 600.0)
    assert(approx(v_t, 2.0, 1e-9), "Charles")

    // First-order half-life: t = ln(2)/k
    t = half_life_first_order(0.5)
    assert(approx(t, 1.3862944, 1e-6), "first-order half-life")

    // ka <-> pka inverse
    Ka = ka_from_pka(4.76)
    pKa = pka_from_ka(Ka)
    assert(approx(pKa, 4.76, 1e-6), "ka<->pka inverse")

    print("stdlib_chemistry_test: all 8 asserts passed")
}

main()
