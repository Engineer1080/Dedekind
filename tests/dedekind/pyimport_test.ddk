// Test fuer `pyimport` — direkter Zugriff auf Python-Module.

pyimport scipy.special as sp
pyimport math

fn approx(a, b, tol) {
    d = a - b
    if d < 0 { d = -d }
    return d < tol
}

fn main() {
    // gamma(5) = 4! = 24
    assert(approx(sp.gamma(5.0), 24.0, 1e-9), "scipy.special.gamma(5)=24")

    // gamma(0.5) = sqrt(pi)
    assert(approx(sp.gamma(0.5), 1.7724538509, 1e-6), "gamma(0.5)=sqrt(pi)")

    // erfc(0) = 1
    assert(approx(sp.erfc(0.0), 1.0, 1e-9), "erfc(0)=1")

    // math.pi vs Dedekind pi
    assert(approx(math.pi, 3.141592653589793, 1e-12), "math.pi konsistent")

    // math.log2(8) = 3
    assert(approx(math.log2(8.0), 3.0, 1e-9), "log2(8)=3")

    // math.factorial(6) = 720
    assert(math.factorial(6) == 720, "factorial(6)=720")

    print("pyimport_test: 6 Asserts bestanden")
}

main()
