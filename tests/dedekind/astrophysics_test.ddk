// Test: Astrophysics & Cosmology Extension

fn test_kepler_solver() {
    // 1. Solving with eccentricity = 0 should yield E = M
    M0 = 0.0
    E0 = solve_kepler(M0, 0.5)
    assert(abs(E0) < 1e-6)

    // 2. Solve Kepler's equation for M=1.0, e=0.5
    M1 = 1.0
    e1 = 0.5
    E1 = solve_kepler(M1, e1)
    // Check if Kepler equation holds: E1 - e1*sin(E1) - M1 = 0
    diff = E1 - e1 * sin(E1) - M1
    assert(abs(diff) < 1e-5)

    // 3. Solve Kepler's equation using degrees for mean anomaly: 90[deg] should convert to pi/2 rad
    E_deg = solve_kepler(90.0[deg], 0.5)
    E_rad = solve_kepler(1.57079632679, 0.5)
    assert(abs(E_deg - E_rad) < 1e-5)

    print("test_kepler_solver: passed.")
}

fn test_redshift() {
    v0 = redshift_to_velocity(0.0)
    assert(abs(v0.value - 0.0) < 1e-6)
    assert(v0.unit == "m/s")

    // For z=0.1
    v1 = redshift_to_velocity(0.1)
    // Relativistic velocity formula: v = c * ((1.1^2 - 1) / (1.1^2 + 1))
    // 1.1^2 = 1.21. (1.21 - 1)/(1.21 + 1) = 0.21/2.21 ≈ 0.0950226 * c
    // v ≈ 0.0950226 * 299792458 = 28487053.4 m/s (approx 28487070.0 in float32)
    assert(abs(v1.value - 28487053.4) < 100.0)
    assert(v1.unit == "m/s")

    print("test_redshift: passed.")
}

fn test_schwarzschild() {
    // Schwarzschild radius of 1 solar mass
    M_val = 1.0[M_sun]
    Rs = schwarzschild_radius(M_val)
    assert(Rs.unit == "m")
    // Rs = 2 * G * M / c^2
    // G ≈ 6.6743e-11, c ≈ 2.99792458e8, M ≈ 1.98847e30
    // Rs = 2 * 6.6743e-11 * 1.98847e30 / (2.99792458e8)^2 ≈ 2953.25 m
    assert(abs(Rs.value - 2953.25) < 1.0)

    print("test_schwarzschild: passed.")
}

fn test_stellar_properties() {
    L1 = stellar_luminosity(1.0[M_sun])
    assert(L1.unit == "L_sun")
    assert(abs(L1.value - 1.0) < 1e-4)

    // For very low mass star (e.g. M = 0.1 M_sun)
    // L = 0.23 * M^2.3 = 0.23 * 0.1^2.3 ≈ 0.0011529
    L01 = stellar_luminosity(0.1[M_sun])
    assert(abs(L01.value - 0.0011529) < 1e-6)

    // For high mass star (e.g. M = 10.0 M_sun)
    // L = 1.4 * M^3.5 = 1.4 * 10^3.5 ≈ 4427.1887
    L10 = stellar_luminosity(10.0[M_sun])
    assert(abs(L10.value - 4427.1887) < 1.0)

    print("test_stellar_properties: passed.")
}

fn test_astrophysics_autograd() {
    fn kepler_helper(x) {
        // x[0] is M, x[1] is e
        res = solve_kepler(x[0], x[1])
        return res
    }
    x_val = [1.0, 0.5]
    J = jacobian(kepler_helper, x_val)
    
    // Test that the Jacobian has the correct shape and is populated
    assert(J.shape[0] == 1)
    assert(J.shape[1] == 2)
    // dE/dM = 1 / (1 - e*cos(E))
    // For M=1, e=0.5, E ≈ 1.4987 -> cos(E) ≈ 0.072 -> dE/dM ≈ 1 / (1 - 0.036) ≈ 1.037
    assert(abs(J[0][0] - 1.037) < 0.05)

    print("test_astrophysics_autograd: passed.")
}

fn main() {
    test_kepler_solver()
    test_redshift()
    test_schwarzschild()
    test_stellar_properties()
    test_astrophysics_autograd()
    print("astrophysics_test: All tests passed!")
}
main()
