// Tests for multi-file modules with visibility (v1.19).
//
// Prerequisite: examples/dedekind/compiler_features/demo_geometry/ exists with pub annotations.

use compiler_features.demo_geometry.area
use compiler_features.demo_geometry.volume
use math      // backward compatibility: no pub -> everything is public

fn approx(a, b, tol) {
    d = a - b
    if d < 0 { d = -d }
    return d < tol
}

fn main() {
    // --- 1. Area calculations from demo_geometry.area ---
    assert(approx(circle_area(1.0), 3.14159265, 1e-6), "circle_area from demo_geometry.area")
    assert(approx(triangle_area(4.0, 3.0), 6.0, 1e-9), "triangle_area from demo_geometry.area")

    // --- 2. Volume calculations from demo_geometry.volume ---
    assert(approx(cube_volume(3.0), 27.0, 1e-9), "cube_volume from demo_geometry.volume")
    assert(approx(sphere_volume(1.0), 4.18879, 1e-4), "sphere_volume from demo_geometry.volume")

    // --- 3. Visibility check: private functions are inaccessible ---
    private_inaccessible = false
    try {
        bad = priv_pi()
        private_inaccessible = false
    } catch e {
        private_inaccessible = true
    }
    assert(private_inaccessible, "priv_pi() is invisible from outside")

    private_inaccessible2 = false
    try {
        bad2 = priv_four_thirds()
        private_inaccessible2 = false
    } catch e {
        private_inaccessible2 = true
    }
    assert(private_inaccessible2, "priv_four_thirds() is invisible")

    private_inaccessible3 = false
    try {
        bad3 = priv_half(10.0)
        private_inaccessible3 = false
    } catch e {
        private_inaccessible3 = true
    }
    assert(private_inaccessible3, "priv_half() is invisible")

    // --- 4. Backward compatibility: module without pub -> everything public ---
    assert(fibonacci(10) == 55, "fibonacci from math (legacy mode)")
    assert(approx(hypotenuse(3.0, 4.0), 5.0, 1e-6), "hypotenuse from math")
    assert(approx(PHI, 1.618033, 1e-4), "PHI from math")

    print("multi_file_modules_test: 10 asserts passed")
}
main()
