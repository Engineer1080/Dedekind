// Test: Zahlentheorie gcd, is_prime, mod, mod_inv, mod_pow
fn main() {
    assert(gcd(12, 8) == 4)
    assert(gcd(17, 19) == 1)

    assert(is_prime(2))
    assert(is_prime(3))
    assert(is_prime(4) == false)
    assert(is_prime(17))

    assert(mod(7, 3) == 1)
    assert(mod(-7, 3) == 2)

    inv = mod_inv(3, 11)
    assert(mod(3 * inv, 11) == 1)

    assert(mod_pow(2, 10, 1000) == 24)

    print("number_theory_test: passed.")
}
main()
