use robotics

fn test_forward_kinematics() {
    print("Testing Forward Kinematics (DH Parameters)...")
    
    // Einfacher planarer 2-Gelenk-Arm
    arm = kinematic_chain()
    arm.add_revolute_joint(0.0[m], 1.0[m], 0.0[rad])
    arm.add_revolute_joint(0.0[m], 1.0[m], 0.0[rad])
    
    // Gelenkwinkel q1 = 90 deg, q2 = -90 deg
    // 90 deg = pi/2 rad. 
    // Erwartete Position (x,y,z): Arm zeigt nach oben (Y=1), dann nach rechts (X=1).
    // Resultat = (1.0, 1.0, 0.0)
    
    q_arr = [1.5707963, -1.5707963]
    T = arm.forward_kinematics(q_arr)
    pos = end_effector_pos(T)
    
    print("End-Effector Position:", pos)
    
    // Check (floating point tolerance)
    assert(abs(pos[0] - 1.0) < 1e-5)
    assert(abs(pos[1] - 1.0) < 1e-5)
    assert(abs(pos[2] - 0.0) < 1e-5)
    
    print("[OK] Forward Kinematics")
}

fn test_jacobian() {
    print("Testing Analytical Jacobian via Autograd...")
    arm = kinematic_chain()
    arm.add_revolute_joint(0.0[m], 1.0[m], 0.0[rad])
    arm.add_revolute_joint(0.0[m], 1.0[m], 0.0[rad])
    
    fn fk_pos(q) {
        T = arm.forward_kinematics(q)
        return end_effector_pos(T)
    }
    
    // Literals for [pi/4, pi/4]
    q = [0.785398, 0.785398]
    
    // Dedekinds geniale Autograd-Features auf Robotik angewendet:
    J = jacobian(fk_pos, q)
    print("Analytische Roboter-Jacobi-Matrix J(q):")
    print(J)
    
    assert(len(J.shape) == 2)
    
    print("[OK] Jacobian")
}

fn main() {
    test_forward_kinematics()
    test_jacobian()
}
