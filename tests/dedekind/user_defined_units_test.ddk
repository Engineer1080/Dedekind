// Tests für `unit NAME = NUMBER[base]` – benutzerdefinierte Einheiten.

unit Foot = 0.3048[m]
unit Mile = 1609.344[m]
unit calorie = 4.184[J]
unit kcal = 1000.0[calorie]      // Verkettung: aliasiert über calorie

fn approx(a, b, tol) {
    d = a - b
    if d < 0 { d = -d }
    return d < tol
}

fn main() {
    // 1) Reine User-Einheit + User-Einheit
    h = 6[Foot] + 6[Foot]
    assert(approx(h.value, 12.0, 1e-9), "Foot+Foot")
    assert(h.unit == "Foot", "Foot-Einheit erhalten")

    // 2) User + Built-in: Ergebnis-Einheit folgt LINKER Seite
    route = 1[Mile] + 1609.344[m]
    assert(approx(route.value, 2.0, 1e-6), "Mile+m: 1 Mile + 1609.344 m = 2 Mile")
    assert(route.unit == "Mile", "Mile-Einheit erhalten")

    // 3) Built-in + User: Ergebnis-Einheit = Built-in
    route2 = 1609.344[m] + 1[Mile]
    assert(approx(route2.value, 3218.688, 1e-6), "m+Mile in Metern")
    assert(route2.unit == "m", "m-Einheit erhalten")

    // 4) Verkettung: kcal -> calorie -> J
    e = 1[kcal] + 1000.0[calorie]
    assert(approx(e.value, 2.0, 1e-9), "kcal + 1000 calorie = 2 kcal")

    // 5) Built-in mit benutzerdefiniertem Alias verträglich
    e_in_J = 1[kcal] + 4184.0[J]
    // 1 kcal + 4184 J = 1 kcal + 1 kcal = 2 kcal
    assert(approx(e_in_J.value, 2.0, 1e-6), "kcal + J kombiniert")

    print("user_defined_units_test: alle 5 Asserts bestanden")
}

main()
