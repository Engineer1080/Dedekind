// Test for md_simulate_lj — OpenMM bridge with unit validation.

fn approx(a, b, tol) {
    d = a - b
    if d < 0 { d = -d }
    return d < tol
}

fn main() {
    // Argon cluster, deterministic via seed
    res = md_simulate_lj(
        n_particles=8,
        sigma=0.34[nm],
        epsilon=0.99[kJ/mol],
        mass=39.95[amu],
        temperature=100[K],
        dt=0.001[ps],
        n_steps=50,
        box_size=1.5[nm],
        seed=123
    )

    // Structural asserts: all fields present, correct types/shapes
    pos = res["positions"]
    assert(pos.shape[0] == 8, "8 particle positions")
    assert(pos.shape[1] == 3, "3-D positions")

    PE = res["potential_energy"]
    KE = res["kinetic_energy"]
    T  = res["temperature"]
    assert(PE.unit == "kJ/mol", "PE is in kJ/mol")
    assert(KE.unit == "kJ/mol", "KE is in kJ/mol")
    assert(T.unit == "K", "temperature is in K")

    // Physical plausibility: KE > 0 (positive kinetic energy)
    assert(KE.value > 0, "KE positive")
    // Equipartition: T should be near 100 K (within 4x — Langevin needs time)
    assert(T.value > 20.0, "temperature > 20 K (Langevin equilibrates)")
    assert(T.value < 400.0, "temperature < 400 K (no runaway)")

    // Alternative units: Angstrom + kcal/mol accepted
    res2 = md_simulate_lj(
        n_particles=8,
        sigma=3.4[Angstrom],
        epsilon=0.238[kcal/mol],
        mass=39.95[amu],
        temperature=100[K],
        dt=1[fs],
        n_steps=20,
        box_size=15[Angstrom],
        seed=123
    )
    assert(res2["positions"].shape[0] == 8, "Angstrom input also yields 8 positions")
    assert(res2["potential_energy"].unit == "kJ/mol", "PE normalized to kJ/mol")

    print("md_simulate_lj_test: 8 asserts passed")
}

main()
