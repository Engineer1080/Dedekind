// Test: Life Sciences Phase 2 - local alignment and protein structure parsing

fn test_smith_waterman_string() {
    res = smith_waterman_alignment("TGCATG", "GGCA", 2.0, -1.0, -1.0)
    score = res["score"]
    aligned_1 = res["aligned_seq1"]
    aligned_2 = res["aligned_seq2"]

    assert(score == 6.0)
    assert(aligned_1 == "GCA")
    assert(aligned_2 == "GCA")
    print("test_smith_waterman_string: bestanden.")
}

fn test_smith_waterman_tensor() {
    s1 = [1, 2, 3, 4, 5]
    s2 = [2, 3, 4]
    res = smith_waterman_alignment(s1, s2, 2.0, -1.0, -1.0)
    score = res["score"]

    assert(score == 6.0)
    print("test_smith_waterman_tensor: bestanden.")
}

fn test_protein_structure_parse() {
    pdb_data = "HEADER    DUMMY PROTEIN
ATOM      1  N   ALA A   1      11.111  22.222  33.333  1.00 15.00           N
ATOM      2  CA  ALA A   1      12.000  23.000  34.000  1.00 16.50           C
HETATM    3  O   HOH A   2      15.000  25.000  35.000  0.50 20.00           O
"
    write_file("./dummy_test.pdb", pdb_data)
    df_pdb = protein_structure_parse("./dummy_test.pdb")

    assert(len(df_pdb) == 3)
    assert(df_pdb["atom_name"][0] == "N")
    assert(df_pdb["atom_name"][1] == "CA")
    assert(df_pdb["res_name"][0] == "ALA")
    assert(df_pdb["chain_id"][0] == "A")
    assert(df_pdb["element"][0] == "N")

    x_coords = df_pdb.column_with_unit("x")
    x0 = x_coords[0]
    assert(abs(x0.value - 11.111) < 1e-3)
    assert(x0.unit == "angstrom")

    y_coords = df_pdb.column_with_unit("y")
    y0 = y_coords[0]
    assert(abs(y0.value - 22.222) < 1e-3)
    assert(y0.unit == "angstrom")

    z_coords = df_pdb.column_with_unit("z")
    z0 = z_coords[0]
    assert(abs(z0.value - 33.333) < 1e-3)
    assert(z0.unit == "angstrom")

    // mmCIF test
    cif_data = "#
loop_
_atom_site.group_PDB
_atom_site.id
_atom_site.type_symbol
_atom_site.label_atom_id
_atom_site.label_comp_id
_atom_site.auth_asym_id
_atom_site.auth_seq_id
_atom_site.Cartn_x
_atom_site.Cartn_y
_atom_site.Cartn_z
_atom_site.occupancy
_atom_site.B_iso_or_equiv
ATOM 1 N N ALA A 1 11.111 22.222 33.333 1.00 15.00
ATOM 2 C CA ALA A 1 12.000 23.000 34.000 1.00 16.50
HETATM 3 O O HOH A 2 15.000 25.000 35.000 0.50 20.00
"
    write_file("./dummy_test.cif", cif_data)
    df_cif = protein_structure_parse("./dummy_test.cif")

    assert(len(df_cif) == 3)
    assert(df_cif["atom_name"][0] == "N")
    assert(df_cif["atom_name"][1] == "CA")
    assert(df_cif["res_name"][0] == "ALA")
    assert(df_cif["chain_id"][0] == "A")
    assert(df_cif["element"][0] == "N")

    x_cif = df_cif.column_with_unit("x")
    assert(abs(x_cif[0].value - 11.111) < 1e-3)
    assert(x_cif[0].unit == "angstrom")

    print("test_protein_structure_parse: bestanden.")
}

fn main() {
    test_smith_waterman_string()
    test_smith_waterman_tensor()
    test_protein_structure_parse()
    print("life_sciences_phase2_test: alles bestanden.")
}
main()
