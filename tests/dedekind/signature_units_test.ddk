// `@units` signature: functions with declared argument/return units
// auto-convert and raise on dimension mismatch.

fn kinetic_energy(m: [kg], v: [m/s]) -> [J] {
    return 0.5 * m * v * v
}

fn main() {
    // Same units: 0.5 * 2 * 3^2 = 9 J
    E = kinetic_energy(2.0[kg], 3.0[m/s])
    assert(E.value > 8.99 and E.value < 9.01, "expected 9 J")
    assert(E.unit == "J", "return unit J")

    // Automatic conversion: 2000 g -> 2 kg
    E2 = kinetic_energy(2000.0[g], 3.0[m/s])
    assert(E2.value > 8.99 and E2.value < 9.01, "2000 g -> 2 kg, same E")

    print("signature_units_test OK")
}
main()
