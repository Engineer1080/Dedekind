// Tests for Navier-Stokes Chorin solver + IBM (Brinkman penalization).

fn make_soft_disk(nx, ny, cx, cy, r) {
    rows = linspace(0.0, nx - 1.0, nx)
    cols = linspace(0.0, ny - 1.0, ny)
    IX   = outer(rows, 1.0 + 0.0 * cols)
    IY   = outer(1.0 + 0.0 * rows, cols)
    d    = sqrt((IX - cx)*(IX - cx) + (IY - cy)*(IY - cy))
    return clip(1.0 - (d - r), 0.0, 1.0)
}

fn test_chorin_no_obstacle() {
    print("Testing Chorin solver without obstacle (Taylor-Green)...")
    nx = 32
    ny = 32
    x  = linspace(0.0, 1.0, nx)
    y  = linspace(0.0, 1.0, ny)
    t  = linspace(0.0, 0.1, 11)
    nu = 0.01

    X  = outer(x, 1.0 + 0.0 * y)
    Y  = outer(1.0 + 0.0 * x, y)
    gx = 2.0 * pi * (X - 0.5)
    gy = 2.0 * pi * (Y - 0.5)
    u0 = -cos(gx) * sin(gy)
    v0 =  sin(gx) * cos(gy)

    result = pde_navier_stokes_2d(u0, v0, x, y, t, nu)

    // Must return a 3-tuple
    assert(len(result) == 3)

    u_sol = result[0]
    v_sol = result[1]

    // Energy must decrease (viscous damping)
    E0 = mean(u_sol[0]  * u_sol[0]  + v_sol[0]  * v_sol[0])
    Ef = mean(u_sol[10] * u_sol[10] + v_sol[10] * v_sol[10])
    print("  KE: ", E0, " -> ", Ef)
    assert(Ef < E0)

    print("[OK] Chorin Taylor-Green energy decay")
}

fn test_ibm_returns_4tuple() {
    print("Testing that IBM returns a 4-tuple with F_history...")
    nx = 24
    ny = 12
    x  = linspace(0.0, 1.0, nx)
    y  = linspace(0.0, 0.5, ny)
    t  = linspace(0.0, 0.02, 5)
    nu = 0.05

    ones2d = outer(1.0 + 0.0 * x, 1.0 + 0.0 * y)
    u0 = 0.1 * ones2d
    v0 = 0.0 * ones2d

    M = make_soft_disk(nx, ny, 8.0, 6.0, 1.5)

    result = pde_navier_stokes_2d(u0, v0, x, y, t, nu,
                                   obstacle_mask=M, rho=1.0)
    assert(len(result) == 4)

    F = result[3]   // (nt, 2)
    print("  F_history shape:", F.shape)
    assert(F.shape[0] == 5)
    assert(F.shape[1] == 2)

    print("[OK] IBM returns the correct 4-tuple")
}

fn test_ibm_noslip_in_solid() {
    print("Testing IBM: no-slip inside the solid (u ~ 0 at cylinder center)...")
    nx = 32
    ny = 16
    x  = linspace(0.0, 2.0, nx)
    y  = linspace(0.0, 1.0, ny)
    t  = linspace(0.0, 0.1, 21)
    nu = 0.02

    ones2d = outer(1.0 + 0.0 * x, 1.0 + 0.0 * y)
    u0 = 0.1 * ones2d
    v0 = 0.0 * ones2d

    cx_g = 10.0
    cy_g = 8.0
    M    = make_soft_disk(nx, ny, cx_g, cy_g, 2.0)

    result = pde_navier_stokes_2d(u0, v0, x, y, t, nu,
                                   obstacle_mask=M, rho=1.0)
    u_sol = result[0]

    u_in  = u_sol[20][10][8]    // cylinder center
    u_out = u_sol[20][10][0]    // far outside

    print("  u in solid:", u_in, "  u outside:", u_out)
    assert(abs(u_in) < 1e-6)
    assert(u_out > abs(u_in))

    print("[OK] No-slip inside the solid")
}

fn test_ibm_drag_positive() {
    print("Testing IBM: drag must be positive (flow is slowed)...")
    nx = 32
    ny = 16
    x  = linspace(0.0, 2.0, nx)
    y  = linspace(0.0, 1.0, ny)
    t  = linspace(0.0, 0.1, 21)
    nu = 0.02

    ones2d = outer(1.0 + 0.0 * x, 1.0 + 0.0 * y)
    u0 = 0.1 * ones2d
    v0 = 0.0 * ones2d

    M = make_soft_disk(nx, ny, 10.0, 8.0, 2.0)

    result = pde_navier_stokes_2d(u0, v0, x, y, t, nu,
                                   obstacle_mask=M, rho=1.0)
    F_hist = result[3]
    drag   = F_hist[20][0]

    print("  Drag Fx:", drag)
    assert(drag > 0.0)

    print("[OK] IBM drag > 0")
}

fn main() {
    test_chorin_no_obstacle()
    test_ibm_returns_4tuple()
    test_ibm_noslip_in_solid()
    test_ibm_drag_positive()
}
main()
