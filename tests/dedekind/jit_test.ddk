// JIT-Backend: jit(fn) wrappt mit torch.compile (oder gibt Original zurück);
// muss in beiden Fällen ein aufrufbares, dasselbe-Ergebnis-Funktion liefern.

fn square_sum(x) {
    return x * x + x
}

fn main() {
    f_jit = jit(square_sum)
    a = square_sum(3.0)
    b = f_jit(3.0)
    assert(abs(a - b) < 1e-6, "jit liefert gleiches Ergebnis wie Original")
    print("jit_test OK")
}
main()
