// Tests für modules/stats.ddk
use stats

fn approx(a, b, tol) {
    d = a - b
    if d < 0 { d = -d }
    return d < tol
}

fn main() {
    // z-score
    assert(approx(z_score(110.0, 100.0, 5.0), 2.0, 1e-9), "z-score")

    // pooled std bei identischen Varianzen
    sp = pooled_std(2.0, 2.0, 10, 10)
    assert(approx(sp, 2.0, 1e-9), "pooled std")

    // Cohen's d
    d = cohens_d(105.0, 100.0, 2.0)
    assert(approx(d, 2.5, 1e-9), "cohens_d")

    // RMSE für identische Vektoren = 0
    assert(approx(rmse([1.0, 2.0, 3.0], [1.0, 2.0, 3.0]), 0.0, 1e-9), "rmse=0")

    // R^2 für perfekte Vorhersage ≈ 1
    r2 = r_squared([1.0, 2.0, 3.0, 4.0], [1.0, 2.0, 3.0, 4.0])
    assert(approx(r2, 1.0, 1e-6), "R^2 perfekt")

    // MAE
    assert(approx(mae([1.0, 2.0, 3.0], [1.5, 2.5, 3.5]), 0.5, 1e-9), "mae")

    // Standard error
    assert(approx(standard_error_mean(10.0, 100), 1.0, 1e-9), "SE")

    print("stdlib_stats_test: alle 7 Asserts bestanden")
}

main()
