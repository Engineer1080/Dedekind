// Test: Spezialfunktionen bessel_j0, bessel_j1, legendre, hypergeom
fn main() {
    x = 0.5
    j0 = bessel_j0(x)
    assert(j0 > 0.9)
    assert(j0 < 1.0)

    j1 = bessel_j1(x)
    assert(j1 > 0.2)
    assert(j1 < 0.3)

    // bessel_j(0, x) = bessel_j0(x)
    j0_alt = bessel_j(0, x)
    assert((j0_alt - j0).abs() < 0.001)

    // legendre(0, x) = 1, legendre(1, x) = x
    p0 = legendre(0, x)
    assert(p0 > 0.99)
    assert(p0 < 1.01)
    p1 = legendre(1, x)
    assert(p1 > 0.49)
    assert(p1 < 0.51)

    // hypergeom(1, 1, 1, 0) = 1
    h = hypergeom(1, 1, 1, 0.0)
    assert(h > 0.99)
    assert(h < 1.01)

    print("special_functions_test: bestanden.")
}
main()
