// Symbolic derivative: diff_sym(expr, x)
fn main() {
    d1 = diff_sym("x^2", "x")
    assert(d1 == "2*x")
    d2 = diff_sym("x^2 + sin(x)", "x")
    assert(d2 == "2*x + cos(x)")
    d3 = diff_sym("exp(x)", "x")
    assert(d3 == "exp(x)")
    d4 = diff_sym("log(x)", "x")
    assert(d4 == "1/x")
    d5 = diff_sym("x*sin(x)", "x")
    print("diff_sym(x*sin(x), x):")
    print(d5)
    print("diff_sym_test: passed.")
}
main()
