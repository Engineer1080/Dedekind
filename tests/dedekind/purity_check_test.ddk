// Positiv-Test: reine Loss/Drift/Diffusion-Funktionen kompilieren OHNE Purity-Fehler.
// Der Negativ-Fall (`print` in loss → CompileError) ist in einem Python-Test in
// tests/python/test_purity_check.py abgedeckt, weil Dedekind selbst kein try/except hat.

fn pure_loss(params, data) {
    x = data[0]
    y = data[1]
    diff = params[0] * x + params[1] - y
    return (diff * diff).sum()
}

fn pure_drift(t, y)    { return 0.05 * y }
fn pure_diff(t, y)     { return 0.2 * y }
fn pure_kernel(x)      { return x * x + 1.0 }

fn approx(a, b, tol) {
    d = a - b
    if d < 0 { d = -d }
    return d < tol
}

fn main() {
    // fit() mit reiner loss
    xs = [1.0, 2.0, 3.0, 4.0]
    ys = [3.1, 5.2, 7.0, 9.1]
    params = fit(pure_loss, [1.0, 1.0], [xs, ys], method="gd", lr=0.01, steps=100)
    assert(len(params) == 2, "fit liefert 2 Parameter")

    // sde_solve mit reinem drift/diffusion
    t = linspace(0.0, 1.0, 11)
    Y = sde_solve(pure_drift, pure_diff, 1.0, t, method="euler_maruyama", seed_value=42)
    assert(len(Y) == 11, "sde_solve liefert 11 Zeitschritte")

    // jit mit reinem Kernel
    jit_kernel = jit(pure_kernel)
    out = jit_kernel(3.0)
    assert(approx(out, 10.0, 1e-6), "jit(pure_kernel)(3) = 10")

    print("purity_check_test: 3 Asserts bestanden")
}

main()
