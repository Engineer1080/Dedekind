// --- Differentiable Robotics Module ---
// Constructor for a new kinematic chain (robot arm)
pub fn kinematic_chain() {
    return KinematicChain()
}

// Extracts the [x, y, z] position from a 4x4 transformation matrix.
// We avoid [:, :] syntax in case the parser does not support it,
// and instead call native Dedekind tensor methods or use lists.
pub fn end_effector_pos(T) {
    return end_effector_pos_batched(T)
}

pub fn end_effector_rot(T) {
    return end_effector_rot_backend(T)
}
