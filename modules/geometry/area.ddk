// Modul: geometry.area — Flaechenberechnungen
// Nutzt pub-Sichtbarkeit: nur `circle_area` und `triangle_area` werden exportiert.

fn priv_half(x) { return x / 2.0 }              // privat: nicht exportiert
fn priv_pi() { return 3.14159265358979 }        // privat

pub fn circle_area(r) {
    return priv_pi() * r * r
}

pub fn triangle_area(base, height) {
    return priv_half(base * height)
}
