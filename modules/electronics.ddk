// Dedekind Standard Library: Electronics
// Provides primitives for Differentiable Circuit Simulation and AC Analysis

pub fn circuit() {
    return Circuit()
}

pub fn phasor(mag, phase) {
    return Phasor(mag, phase)
}

pub fn parallel_resistors(R1, R2) {
    return (R1 * R2) / (R1 + R2)
}

pub fn rc_time_constant(R, C) {
    return R * C
}

pub fn rlc_resonance_freq(L, C) {
    return 1.0 / (2.0 * pi * (L * C)^0.5)
}
