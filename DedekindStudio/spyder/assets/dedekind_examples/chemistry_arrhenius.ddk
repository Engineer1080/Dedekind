fn main() {
    print("--- Dedekind: Arrhenius (Quick-Win) ---")

    // k = A * exp(-Ea / (R*T)); T in K, Ea in J/mol
    T = 300.0
    A = 1.0e12
    Ea = 50000.0

    k = arrhenius(T, A, Ea)
    print("Temperatur T (K):")
    print(T)
    print("Präexponent A (1/s), Ea (J/mol):")
    print(A)
    print(Ea)
    print("Geschwindigkeitskonstante k (1/s):")
    print(k)

    print("\nArrhenius aktiv.")
}
main()
